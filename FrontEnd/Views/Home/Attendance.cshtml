@{
    ViewBag.Title = "Attendance Page";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2><i class="fas fa-calendar-check"></i> Attendance Page</h2>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#calendarModal">
                <i class="fas fa-calendar-plus"></i> New Attendance
            </button>
        </div>
    </div>

    <div class="row">
        <!-- Calendar Section -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h6 class="m-0 font-weight-bold">Calendar</h6>
                </div>
                <div class="card-body">
                    <div id="calendar"></div>
                </div>
            </div>
        </div>

        <!-- Employee List Section -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h6 class="m-0 font-weight-bold">Employee name list</h6>
                </div>
                <div class="card-body">
                    <!-- Search Box -->
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" placeholder="Search employee..." id="searchEmployee">
                        <button class="btn btn-outline-secondary" type="button">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>

                    <!-- Employee List with Status -->
                    <div class="employee-list" style="max-height: 500px; overflow-y: auto;">
                        <!-- IT Department -->
                        <h6 class="mt-3 mb-2 text-primary">Department: IT</h6>
                        <div class="list-group mb-3">
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="fas fa-user-circle me-2"></i>
                                    John Doe
                                </div>
                                <span class="badge bg-success">Present</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="fas fa-user-circle me-2"></i>
                                    Jane Smith
                                </div>
                                <span class="badge bg-success">Present</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="fas fa-user-circle me-2"></i>
                                    Mike Johnson
                                </div>
                                <span class="badge bg-danger">Absent</span>
                            </div>
                        </div>

                        <!-- HR Department -->
                        <h6 class="mt-3 mb-2 text-success">Department: HR</h6>
                        <div class="list-group mb-3">
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="fas fa-user-circle me-2"></i>
                                    Sarah Wilson
                                </div>
                                <span class="badge bg-warning">Late</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="fas fa-user-circle me-2"></i>
                                    Tom Brown
                                </div>
                                <span class="badge bg-success">Present</span>
                            </div>
                        </div>

                        <!-- Finance Department -->
                        <h6 class="mt-3 mb-2 text-info">Department: Finance</h6>
                        <div class="list-group mb-3">
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="fas fa-user-circle me-2"></i>
                                    Lisa Davis
                                </div>
                                <span class="badge bg-success">Present</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="fas fa-user-circle me-2"></i>
                                    Robert Wilson
                                </div>
                                <span class="badge bg-danger">Absent</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Calendar Modal (as shown in your PPT) -->
<div class="modal fade" id="calendarModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fas fa-calendar-alt me-2"></i>Mark Attendance
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="attendanceForm">
                    <div class="mb-3">
                        <label class="form-label">Date (YY:MM:DD)</label>
                        <input type="date" class="form-control" id="attendanceDate" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Department</label>
                        <select class="form-select" id="deptSelect" onchange="loadEmployees()">
                            <option>IT Department</option>
                            <option>HR Department</option>
                            <option>Finance Department</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Employee</label>
                        <select class="form-select" id="employeeSelect">
                            <option>John Doe</option>
                            <option>Jane Smith</option>
                            <option>Mike Johnson</option>
                            <option>Sarah Wilson</option>
                            <option>Tom Brown</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="status" id="present" value="Present" checked>
                                <label class="form-check-label text-success" for="present">Present</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="status" id="absent" value="Absent">
                                <label class="form-check-label text-danger" for="absent">Absent</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="status" id="late" value="Late">
                                <label class="form-check-label text-warning" for="late">Late</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveAttendance()">
                    <i class="fas fa-check me-2"></i>OK
                </button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <!-- FullCalendar -->
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css' rel='stylesheet' />
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js'></script>

    <script>
        $(document).ready(function () {
            initializeCalendar();

            // Search functionality
            $('#searchEmployee').on('keyup', function () {
                var searchTerm = $(this).val().toLowerCase();
                $('.employee-list .list-group-item').each(function () {
                    var text = $(this).text().toLowerCase();
                    if (text.includes(searchTerm)) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            });
        });

        function initializeCalendar() {
            var calendarEl = document.getElementById('calendar');
            if (calendarEl) {
                var calendar = new FullCalendar.Calendar(calendarEl, {
                    initialView: 'dayGridMonth',
                    headerToolbar: {
                        left: 'prev,next today',
                        center: 'title',
                        right: 'dayGridMonth,dayGridWeek'
                    },
                    events: [
                        {
                            title: 'John Doe - Present',
                            start: '2024-03-01',
                            color: '#1cc88a'
                        },
                        {
                            title: 'Jane Smith - Present',
                            start: '2024-03-01',
                            color: '#1cc88a'
                        },
                        {
                            title: 'Mike Johnson - Absent',
                            start: '2024-03-01',
                            color: '#e74a3b'
                        },
                        {
                            title: 'Sarah Wilson - Late',
                            start: '2024-03-02',
                            color: '#f6c23e'
                        }
                    ],
                    dateClick: function (info) {
                        $('#attendanceDate').val(info.dateStr);
                        $('#calendarModal').modal('show');
                    }
                });
                calendar.render();
            }
        }

        function loadEmployees() {
            var dept = $('#deptSelect').val();
            var employeeSelect = $('#employeeSelect');
            employeeSelect.empty();

            if (dept.includes('IT')) {
                employeeSelect.append('<option>John Doe</option><option>Jane Smith</option><option>Mike Johnson</option>');
            } else if (dept.includes('HR')) {
                employeeSelect.append('<option>Sarah Wilson</option><option>Tom Brown</option>');
            } else {
                employeeSelect.append('<option>Lisa Davis</option><option>Robert Wilson</option>');
            }
        }

        function saveAttendance() {
            var date = $('#attendanceDate').val();
            var employee = $('#employeeSelect').val();
            var status = $('input[name="status"]:checked').val();

            alert('Attendance marked for ' + employee + ' on ' + date + ': ' + status);
            $('#calendarModal').modal('hide');

            // In real app, refresh calendar
            location.reload();
        }
    </script>
}
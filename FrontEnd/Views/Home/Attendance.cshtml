@{
    ViewBag.Title = "Attendance Page";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2><i class="fas fa-calendar-check me-2"></i>Attendance Page</h2>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#attendanceModal">
                <i class="fas fa-plus me-2"></i>Mark Attendance
            </button>
        </div>
    </div>

    <div class="row">
        <!-- Employee List with Status -->
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-list me-2"></i>Employee Attendance</h5>
                </div>
                <div class="card-body">
                    <!-- Filters -->
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <select class="form-select" id="attendanceDeptFilter">
                                <option value="">All Departments</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <select class="form-select" id="attendanceStatusFilter">
                                <option value="">All Status</option>
                                <option value="Present">Present</option>
                                <option value="Absent">Absent</option>
                                <option value="Late">Late</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <input type="date" class="form-control" id="attendanceDate" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                        </div>
                    </div>

                    <!-- Employee Table -->
                    <div class="table-responsive">
                        <table class="table table-hover" id="attendanceTable">
                            <thead>
                                <tr>
                                    <th>Employee Name</th>
                                    <th>Department</th>
                                    <th>Position</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="attendanceTableBody">
                                <!-- Filled by JavaScript -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Mark Attendance Modal -->
<div class="modal fade" id="attendanceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fas fa-calendar-check me-2"></i>Mark Attendance
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="attendanceForm">
                    <div class="mb-3">
                        <label class="form-label">Date</label>
                        <input type="date" class="form-control" id="modalAttendanceDate" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Employee</label>
                        <select class="form-select" id="attendanceEmployee" required>
                            <option value="">Select employee...</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="attendanceStatus" id="statusPresent" value="Present" checked>
                                <label class="form-check-label text-success" for="statusPresent">Present</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="attendanceStatus" id="statusAbsent" value="Absent">
                                <label class="form-check-label text-danger" for="statusAbsent">Absent</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="attendanceStatus" id="statusLate" value="Late">
                                <label class="form-check-label text-warning" for="statusLate">Late</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveAttendance()">
                    <i class="fas fa-save me-2"></i>Save
                </button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        let employees = JSON.parse(localStorage.getItem('employees')) || [];
        let departments = JSON.parse(localStorage.getItem('departments')) || [];
        let attendanceRecords = JSON.parse(localStorage.getItem('attendanceRecords')) || [];

        $(document).ready(function () {
            updateDepartmentFilter();
            renderAttendanceTable();

            // Filter events
            $('#attendanceDeptFilter, #attendanceStatusFilter, #attendanceDate').change(function () {
                renderAttendanceTable();
            });

            // Update employee dropdown when modal opens
            $('#attendanceModal').on('show.bs.modal', function () {
                updateEmployeeDropdown();
            });
        });

        function updateDepartmentFilter() {
            let options = '<option value="">All Departments</option>';
            departments.forEach(dept => {
                options += `<option value="${dept.name}">${dept.name}</option>`;
            });
            $('#attendanceDeptFilter').html(options);
        }

        function updateEmployeeDropdown() {
            let options = '<option value="">Select employee...</option>';
            employees.forEach(emp => {
                options += `<option value="${emp.id}">${emp.name} (${emp.department})</option>`;
            });
            $('#attendanceEmployee').html(options);
        }

        function renderAttendanceTable() {
            const deptFilter = $('#attendanceDeptFilter').val();
            const statusFilter = $('#attendanceStatusFilter').val();
            const dateFilter = $('#attendanceDate').val();

            let filteredEmployees = [...employees];

            // Apply department filter
            if (deptFilter) {
                filteredEmployees = filteredEmployees.filter(emp => emp.department === deptFilter);
            }

            const tbody = $('#attendanceTableBody');
            tbody.empty();

            if (filteredEmployees.length === 0) {
                tbody.append('<tr><td colspan="5" class="text-center">No employees found</td></tr>');
                return;
            }

            filteredEmployees.forEach(emp => {
                // Get attendance for this employee on selected date
                const record = attendanceRecords.find(r => r.employeeId === emp.id && r.date === dateFilter);
                const status = record ? record.status : 'Not Marked';

                // Apply status filter
                if (statusFilter && status !== statusFilter) {
                    return;
                }

                const statusBadge = getStatusBadge(status);

                const row = `
                        <tr>
                            <td><i class="fas fa-user-circle me-2"></i>${emp.name}</td>
                            <td>${emp.department}</td>
                            <td>${emp.position || 'Staff'}</td>
                            <td>${statusBadge}</td>
                            <td>
                                ${status === 'Not Marked' ?
                        `<button class="btn btn-sm btn-primary" onclick="markAttendance('${emp.id}')">
                                        <i class="fas fa-check me-1"></i>Mark
                                    </button>` :
                        `<button class="btn btn-sm btn-warning" onclick="editAttendance('${emp.id}')">
                                        <i class="fas fa-edit me-1"></i>Edit
                                    </button>`
                    }
                            </td>
                        </tr>
                    `;
                tbody.append(row);
            });
        }

        function getStatusBadge(status) {
            switch (status) {
                case 'Present':
                    return '<span class="badge bg-success">Present</span>';
                case 'Absent':
                    return '<span class="badge bg-danger">Absent</span>';
                case 'Late':
                    return '<span class="badge bg-warning">Late</span>';
                default:
                    return '<span class="badge bg-secondary">Not Marked</span>';
            }
        }

        function markAttendance(employeeId) {
            $('#attendanceEmployee').val(employeeId);
            $('#attendanceModal').modal('show');
        }

        function editAttendance(employeeId) {
            const date = $('#attendanceDate').val();
            const record = attendanceRecords.find(r => r.employeeId === employeeId && r.date === date);

            if (record) {
                $('#attendanceEmployee').val(employeeId);
                $('#modalAttendanceDate').val(date);

                // Set radio button
                $(`input[name="attendanceStatus"][value="${record.status}"]`).prop('checked', true);

                $('#attendanceModal').modal('show');

                // Change save button to update
                $('.btn-primary').text('Update').attr('onclick', 'updateAttendance()');
            }
        }

        function saveAttendance() {
            const employeeId = $('#attendanceEmployee').val();
            const date = $('#modalAttendanceDate').val();
            const status = $('input[name="attendanceStatus"]:checked').val();

            if (!employeeId) {
                alert('Please select an employee');
                return;
            }

            // Check if record already exists
            const existingIndex = attendanceRecords.findIndex(r => r.employeeId === employeeId && r.date === date);

            const record = {
                employeeId: employeeId,
                date: date,
                status: status,
                timestamp: new Date().toISOString()
            };

            if (existingIndex >= 0) {
                attendanceRecords[existingIndex] = record;
            } else {
                attendanceRecords.push(record);
            }

            localStorage.setItem('attendanceRecords', JSON.stringify(attendanceRecords));

            // Reset and close modal
            $('#attendanceForm')[0].reset();
            $('#attendanceModal').modal('hide');

            // Refresh table
            renderAttendanceTable();

            alert('Attendance saved successfully!');
        }

        function updateAttendance() {
            // Reuse save function
            saveAttendance();
            // Reset button
            $('.btn-primary').text('Save').attr('onclick', 'saveAttendance()');
        }
    </script>
}
@section scripts {
    <script src="~/Scripts/api-service.js"></script>
    <script>
        let departments = [];
        let employees = [];

        $(document).ready(function () {
            loadData();
        });

        // Load data from API instead of localStorage
        async function loadData() {
            try {
                // Show loading indicator
                $('.spinner-overlay').show();

                // Fetch data from API
                departments = await ApiService.getDepartments() || [];
                employees = await ApiService.getEmployees() || [];

                renderDepartments();
                updateDepartmentDropdowns();
            } catch (error) {
                alert('Failed to load data. Please try again.');
                console.error(error);
            } finally {
                $('.spinner-overlay').hide();
            }
        }

        // Save new employee to API
        async function saveEmployee() {
            const empName = $('#empName').val().trim();
            const empDept = $('#empDepartment').val();
            const empPosition = $('#empPosition').val().trim();

            if (!empName || !empDept) {
                alert('Please fill in all required fields');
                return;
            }

            const newEmp = {
                name: empName,
                department: empDept,
                position: empPosition || 'Staff',
                status: 'Present'
            };

            try {
                const result = await ApiService.addEmployee(newEmp);

                if (result) {
                    alert('Employee added successfully!');
                    $('#addEmployeeModal').modal('hide');
                    $('#addEmployeeForm')[0].reset();

                    // Reload data to show new employee
                    await loadData();
                }
            } catch (error) {
                alert('Failed to add employee. Please try again.');
            }
        }

        // Delete employee via API
        async function deleteEmployee(empId) {
            if (!confirm('Are you sure you want to delete this employee?')) return;

            try {
                const result = await ApiService.deleteEmployee(empId);

                if (result) {
                    alert('Employee deleted successfully!');
                    await loadData(); // Reload data
                }
            } catch (error) {
                alert('Failed to delete employee. Please try again.');
            }
        }

        // Save new department to API
        async function saveDepartment() {
            const deptName = $('#deptName').val().trim();
            const deptColor = $('#deptColor').val();

            if (!deptName) {
                alert('Please enter department name');
                return;
            }

            const newDept = {
                name: deptName,
                color: deptColor
            };

            try {
                const result = await ApiService.addDepartment(newDept);

                if (result) {
                    alert('Department added successfully!');
                    $('#addDepartmentModal').modal('hide');
                    $('#addDepartmentForm')[0].reset();
                    await loadData(); // Reload data
                }
            } catch (error) {
                alert('Failed to add department. Please try again.');
            }
        }

            // Rest of your functions (renderDepartments, etc.) remain the same
            // but they will use the data loaded from API instead of localStorage
    </script>
}